PORT=8787
API_SCANNER_CONCURRENCY=2
API_SCANNER_TIMEOUT_MS=12000

# Auth — required for login and token verification
AUTH_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# CORS — set to your frontend URL (e.g. http://localhost:5173 in dev, https://your-app.up.railway.app in prod)
FRONTEND_ORIGIN=http://localhost:5173
