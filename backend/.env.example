PORT=8787
API_SCANNER_CONCURRENCY=2
API_SCANNER_TIMEOUT_MS=12000

# Auth — required for login and token verification
AUTH_SECRET=change-me-to-a-long-random-string

# CORS — set to your frontend URL
FRONTEND_ORIGIN=http://localhost:5173

# Users are stored in backend/data/users.json — manage with:
#   node backend/scripts/manage-users.js add <email> <password> [admin|user]
#   node backend/scripts/manage-users.js list
