{
  "name": "api-scanner",
  "private": true,
  "version": "1.0.0",
  "description": "Client-side web security scanner — secrets detection, header auditing, SQLi, NoSQL, and XSS testing. No backend, no tracking.",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "@rollup/plugin-commonjs": "^25.0.7"
  }
}
